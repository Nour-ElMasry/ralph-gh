# ralph-gh.conf - Global configuration
# Copy to ~/.ralph-gh/ralph-gh.conf and edit
#
# Repo and workspace are auto-detected from CWD (just cd into your repo).
# Override per-repo settings in .ralphrc at your repo root.

# Optional (defaults shown)
RALPH_GH_LABEL="ralph"                    # Label that triggers automation
RALPH_GH_SKIP_LABEL=""                    # Optional hold label (HITL). Issues with this label
                                           # are deferred: parents are skipped at poll time, held
                                           # sub-issues do not block their dependents (those run
                                           # anyway), and the parent is left open with the held
                                           # slice unchecked so a future run can resume it after
                                           # a human removes the label. Empty = feature disabled.
RALPH_GH_MAIN_BRANCH="main"              # Base branch for PRs
CLAUDE_TIMEOUT_MINUTES=15                 # Max time per sub-issue

# Allowed tools for Claude Code CLI
# Comma-separated list of tool permissions
RALPH_GH_ALLOWED_TOOLS="Write,Read,Edit,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(npm *),Bash(pnpm *),Bash(node *),Bash(find *)"

# Loop control
RALPH_GH_MAX_LOOPS_PER_ISSUE=5           # Max Claude invocations per sub-issue (retries until complete)
RALPH_GH_MAX_LOOPS_TOTAL=0              # Max total invocations per parent group (0=unlimited)

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3               # Open after N sub-issues with no progress
CB_SAME_ERROR_THRESHOLD=5                # Open after N repeated errors

# Parallel execution (experimental — disabled by default)
# When 0, every parent runs its sub-issues serially regardless of any
# `max_parallel` field declared in the PRD DAG. When 1, parents whose DAG
# declares parallelism and whose RALPH_MAX_PARALLEL is >1 will hand off to
# the parallel scheduler (lib/parallel_orchestrator.sh).
# Known issue: env-dependent post-merge verify (e.g. Next.js builds reading
# gitignored .env files) can cascade-fail across parallel sub-worktrees, which
# is why the default is off. Re-enable only if your post-merge gate is
# environment-independent.
RALPH_PARALLEL_ENABLED=0
RALPH_MAX_PARALLEL=1                     # Honored only when RALPH_PARALLEL_ENABLED=1
